; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   name=value ; assign (can use comments)
;   name : type
; Examples:
;   render/vsync=false
;   render/screen_vsync_mode = 1
;   name = 1 or name = "1" makes it a string
;   name = true makes it a boolean
;   name : Color(0, 0, 0, 1) gives Color with alpha


config_version=5

[application]

config/name="칼의 지배 (Sword Dominance)"
config/version="0.1.0"
config/description="메탈슬러그 스타일의 고려시대 횡스크롤 액션 게임"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.2")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_layers"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true

[physics]

2d/gravity=980

